#!/bin/sh
# er-system — machine overview
# Format: markdown

hostname=$(hostname)
os_ver=$(sw_vers -productVersion 2>/dev/null || uname -r)
chip=$(sysctl -n machdep.cpu.brand_string 2>/dev/null || uname -m)
cores=$(sysctl -n hw.ncpu 2>/dev/null || echo "?")
mem_bytes=$(sysctl -n hw.memsize 2>/dev/null || echo "0")
mem_gb=$((mem_bytes / 1073741824))
uptime_str=$(uptime | sed 's/.*up/up/' | sed 's/,.*//')

echo "# $hostname"
echo ""
echo "- **macOS** $os_ver"
echo "- **Chip** $chip"
echo "- **Cores** $cores"
echo "- **Memory** ${mem_gb}GB"
echo "- **Uptime** $uptime_str"

echo ""
echo "## Disk"
echo ""
echo '```'
df -h / | awk 'NR==1{print} NR==2{print}'
echo '```'

echo ""
echo "## Load"
echo ""
load=$(sysctl -n vm.loadavg 2>/dev/null | tr -d '{}' || uptime | awk -F'load averages:' '{print $2}')
echo "Load average: **$load**"

echo ""
echo "## Top Processes (by CPU)"
echo ""
echo '```'
ps aux -r | head -6 | awk '{printf "%-8s %-5s %-5s %s\n", $1, $3"%", $4"%", $11}'
echo '```'
